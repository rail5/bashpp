# Find the Bash++ compiler
@class bpp {
	@public path="bin/bpp"
	@public full_path="@(realpath @this.path)"

	@constructor {
		if [[ ! -f "@this.path" ]]; then
			echo "The bpp compiler was not found at @this.path"
			echo "Run 'make' to build the compiler, and run the test suite via 'make test'"
			echo "CWD: $(pwd)"
			exit 1
		fi
	}
}

@bpp compiler

# Get the locally-installed version of Bash
majorVersion=@(awk -F. '{print $1}' <<< "$BASH_VERSION")
minorVersion=@(awk -F. '{print $2}' <<< "$BASH_VERSION")

# Set a flag if we are running in a tty
in_tty=false

if [[ -t 1 ]]; then
	in_tty=true
fi

# Verify that grep supports Perl-compatible regular expressions (`-P` flag)
if ! grep -P -x "abc" <<<"abc" &>/dev/null; then
	echo "Error: The 'grep' command on this system does not support Perl-compatible regular expressions (PCRE)."
	echo "The test suite requires a version of 'grep' with PCRE support to function correctly."
	echo "Please install GNU grep or ensure that your version of grep is built with PCRE support."
	exit 1
fi
