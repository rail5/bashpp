@class Base {	
}

@class Derived : Base {
	@destructor {
		echo "Derived destructor called"
	}
}

@class FurtherDerived : Derived {
	@destructor {
		echo "FurtherDerived destructor called"
	}
}

@class AnotherDerived : Derived {
	@destructor {
		echo "AnotherDerived destructor called"
	}
}

@class EvenFurtherDerived : FurtherDerived {
	# No destructor defined here
}

@class FurthestDerived : EvenFurtherDerived {
	@destructor {
		echo "FurthestDerived destructor called"
	}
}

@Base baseObj
@delete @baseObj # Nothing should be echoed

@Derived derivedObj
@delete @derivedObj # "Derived destructor called"

@FurtherDerived furtherDerivedObj
@delete @furtherDerivedObj # "FurtherDerived destructor called" followed by "Derived destructor called"

@AnotherDerived anotherDerivedObj
@delete @anotherDerivedObj # "AnotherDerived destructor called" followed by "Derived destructor called"

@EvenFurtherDerived evenFurtherDerivedObj
@delete @evenFurtherDerivedObj # "FurtherDerived destructor called" followed by "Derived destructor called"

@FurthestDerived furthestDerivedObj
@delete @furthestDerivedObj # "FurthestDerived destructor called" followed by "FurtherDerived destructor called" followed by "Derived destructor called"

# And test with pointers:

@Base* basePtr=@new Base
@delete @basePtr # Nothing should be echoed

@Derived* derivedPtr=@new Derived
@delete @derivedPtr # "Derived destructor called"

@FurtherDerived* furtherDerivedPtr=@new FurtherDerived
@delete @furtherDerivedPtr # "FurtherDerived destructor called" followed by "Derived destructor called"

@AnotherDerived* anotherDerivedPtr=@new AnotherDerived
@delete @anotherDerivedPtr # "AnotherDerived destructor called" followed by "Derived destructor called"

@EvenFurtherDerived* evenFurtherDerivedPtr=@new EvenFurtherDerived
@delete @evenFurtherDerivedPtr # "FurtherDerived destructor called" followed by "Derived destructor called"

@FurthestDerived* furthestDerivedPtr=@new FurthestDerived
@delete @furthestDerivedPtr # "FurthestDerived destructor called" followed by "FurtherDerived destructor called" followed by "Derived destructor called"
