{
  "grammars": [
    {
      "name": "bashpp",
      "camelcase": "Bashpp",
      "scope": "source.bashpp",
      "path": ".",
      "file-types": [
        "bpp"
      ],
      "injection-regex": "^(bashpp|bpp)$",
      "first-line-regex": "^#!.*\\b(bpp)\\b.*$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "GPL-3.0-or-later",
    "description": "Bash++ grammar for Tree-sitter",
    "authors": [
      {
        "name": "Bash++ contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/rail5/bashpp"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
